# Local overlay-dev environment.
#
# Copy to .env (gitignored) for tool-CLI smoke tests:
#
#     cp .env.example .env
#     uv run python -m tools.semantic_scholar.cli search "diffusion models"
#
# The tool CLIs use ``load_dotenv`` to pick up these values for ad-hoc
# local runs. **Cluster deploys read nothing from this file** — secrets
# in production are resolved via Centaur's secret manager (see
# `centaur_sdk.secret`), and the cluster-side bootstrap (which used to
# live alongside this template) now lives in the sibling
# centaur-lab-infra repo.

# Optional. Semantic Scholar Graph API key — works without it (heavily
# rate-limited). Apply for a key at:
# https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# Required for the upstream `archiver` tool (PDF + document extraction via
# Reducto). Get a key at https://platform.reducto.ai/
REDUCTO_API_KEY=

# Required by the upstream `archiver` tool when extracting from gated sources
# (DocSend, etc.) via Browser Use cloud. Get a key at
# https://browser-use.com/
BROWSER_USE_API_KEY=

# Required for the upstream `websearch` tool (Exa search + cited synthesis).
# Get a key at https://exa.ai/
EXA_API_KEY=

# Required by `websearch.search(synthesize=True)` and
# `websearch.deep_research(...)` for Claude-backed citation synthesis.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
