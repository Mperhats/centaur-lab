# centaur-lab MVP environment variables.
#
# Onboarding:
#   1. cp .env.example .env
#   2. Replace the ANTHROPIC_API_KEY placeholder with a real Anthropic key.
#   3. With slackbot enabled, fill SLACK_BOT_TOKEN and SLACK_SIGNING_SECRET
#      from your Slack App's Install App / Basic Information pages. Random
#      hex would silently break webhook signature validation and bot API
#      calls — Slack returns invalid_auth and you'll wonder why nothing
#      works.
#   4. For each "replace-with-random-hex" placeholder, run `openssl rand -hex 32`
#      and paste the output. These are genuinely ceremonial — never reach
#      the network in env-mode but the upstream bootstrap script's
#      preconditions require them to be set. Generate once and keep stable.
#   5. source .env
#   6. just up
#
# The `export` prefix matters: `just bootstrap-secrets` reads from your
# exported shell environment, so bare KEY=value lines would not be picked up.
#
# NOTE: SANDBOX_SIGNING_KEY and IRON_MANAGEMENT_API_KEY do NOT appear here.
# The upstream bootstrap-k8s-secrets.sh GENERATES them itself (random hex per
# fresh Secret) and persists the values across subsequent `just up` runs.

# Real Anthropic key. Threaded into centaur-infra-env via `kubectl patch`
# after the upstream bootstrap script runs (the upstream script hardcodes
# which keys land in the Secret and does not include ANTHROPIC_API_KEY).
export ANTHROPIC_API_KEY=sk-ant-replace-me

# Real Slack credentials, required because slackbot.enabled=true in
# values.local.yaml. SLACK_BOT_TOKEN authenticates outbound calls to Slack;
# SLACK_SIGNING_SECRET verifies inbound webhook signatures from Slack.
export SLACK_BOT_TOKEN=xoxb-replace-me
export SLACK_SIGNING_SECRET=replace-with-slack-signing-secret

# Genuinely ceremonial — required by the upstream bootstrap script's
# preconditions but never used in env-mode (OP_*) or only used internally
# between the API and slackbot pods, where both read the same value from
# the same Secret (SLACKBOT_API_KEY). Random hex placeholders are fine.
export OP_SERVICE_ACCOUNT_TOKEN=replace-with-random-hex
export OP_VAULT=replace-with-random-hex
export SLACKBOT_API_KEY=replace-with-random-hex

# Tooling: makes `.centaur/Justfile`'s passthrough recipes (`bootstrap-secrets`,
# `status`, `logs`, `smoke`) target the same namespace our root `up`/`down`
# use. Upstream's default is `centaur`; we deploy into `centaur-system`.
export CENTAUR_NAMESPACE=centaur-system
