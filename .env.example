# centaur-lab MVP environment variables.
#
# Onboarding:
#   1. cp .env.example .env
#   2. Replace each "replace-with-*" placeholder with a real value (see the
#      "Real credentials" section below for where each comes from).
#   3. For each "replace-with-random-hex" placeholder, run
#      `openssl rand -hex 32` and paste the output. These are ceremonial —
#      required by the upstream bootstrap script's preconditions but never
#      reach the network in env-mode. Generate once and keep stable.
#   4. just up
#
# No `source .env` step: the Justfile sets `dotenv-load := true` (matching
# upstream's `.centaur/Justfile`), so every recipe loads this file
# automatically. The `export` prefix is harmless — just's dotenv parser
# accepts both `KEY=value` and `export KEY=value`.
#
# NOTE: SANDBOX_SIGNING_KEY and IRON_MANAGEMENT_API_KEY do NOT appear here.
# The upstream bootstrap-k8s-secrets.sh GENERATES them itself (random hex per
# fresh Secret) and persists the values across subsequent `just up` runs.

# --- Real credentials ----------------------------------------------------

# Harness keys. Patched into `centaur-infra-env` by our root Justfile;
# upstream's bootstrap script does not handle them. iron-proxy in env-mode
# reads from this Secret to inject on outbound calls to api.anthropic.com
# and api.openai.com respectively. ANTHROPIC_API_KEY is required because
# `api.defaultHarness: claude-code` in values.local.yaml. OPENAI_API_KEY
# only matters if you @bot with the `--codex` selector; leave unset to
# disable Codex.
export ANTHROPIC_API_KEY=sk-ant-replace-me
export OPENAI_API_KEY=sk-oai-replace-me

# Slack app credentials. Required because `slackbot.enabled: true` in
# values.local.yaml. SLACK_BOT_TOKEN authenticates outbound calls to Slack;
# SLACK_SIGNING_SECRET verifies inbound webhook signatures. Find both in
# your Slack app at api.slack.com/apps:
#   - SLACK_BOT_TOKEN: OAuth & Permissions -> Bot User OAuth Token (xoxb-)
#   - SLACK_SIGNING_SECRET: Basic Information -> App Credentials
export SLACK_BOT_TOKEN=xoxb-replace-me
export SLACK_SIGNING_SECRET=replace-with-slack-signing-secret

# Slack ETL user token. Required when `api.slackEtlEnabled: true` in
# values.local.yaml. This is a Slack USER token (xoxp-), not the bot token,
# with read scopes: `conversations.list`, `conversations.history`,
# `conversations.replies`, `users.list`. Patched into `centaur-infra-env`
# alongside the harness keys. Leave unset to disable Slack history sync.
# See https://centaur.run/operate/slack-etl for token setup details.
export SLACK_ETL_TOKEN=xoxp-replace-me

# github_issue_triage workflow. Both keys are OPTIONAL — leave unset to
# disable the workflow; bootstrap-secrets skips unset keys.
#
# GITHUB_WEBHOOK_SECRET verifies HMAC signatures on inbound GitHub webhooks
# at https://centaur.local-labs.xyz/api/webhooks/github-issue-triage.
# Generate once: `openssl rand -hex 32`. The same value must be configured
# in each GitHub repo's webhook settings (Settings -> Webhooks -> Secret).
#
# GITHUB_TOKEN is the agent's PAT for actually posting the triage comment.
# Use a fine-grained token scoped to: Issues (read+write) + Metadata (read).
# Create at https://github.com/settings/personal-access-tokens/new.
export GITHUB_WEBHOOK_SECRET=replace-with-random-hex
export GITHUB_TOKEN=github_pat_replace-me

# Optional. semantic_scholar overlay tool (overlay/tools/semantic_scholar).
# The Graph API works without a key (heavily rate-limited), so leave this
# unset for casual use. Apply for a key for higher quota:
# https://www.semanticscholar.org/product/api#api-key-form
# When set, bootstrap-secrets patches it into centaur-infra-env; iron-proxy
# injects the `x-api-key` header on outbound requests to api.semanticscholar.org.
export SEMANTIC_SCHOLAR_API_KEY=replace-me-or-leave-unset

# --- Ceremonial random hex -----------------------------------------------

# Required by the upstream bootstrap script's preconditions but never used
# in env-mode (OP_*) or only used internally between the API and slackbot
# pods, where both read the same value from the same Secret (SLACKBOT_API_KEY).
export OP_SERVICE_ACCOUNT_TOKEN=replace-with-random-hex
export OP_VAULT=replace-with-random-hex
export SLACKBOT_API_KEY=replace-with-random-hex

# Long-lived operator/admin API key. On API startup,
# `bootstrap_service_api_keys()` reads this env var and seeds a row in the
# Postgres `api_keys` table as `service:local-dev` with scopes
# (admin, agent, threads, tools:*). Use it to hit /workflows/*, /admin/*,
# and any other endpoint behind a real API key — there is no localhost
# bypass. Generate once with: printf 'aiv2_%s\n' "$(openssl rand -hex 24)"
export LOCAL_DEV_API_KEY=aiv2_replace-with-random-hex


# --- Tooling -------------------------------------------------------------

# Makes `.centaur/Justfile`'s passthrough recipes (`bootstrap-secrets`,
# `status`, `logs`, `smoke`) target the same namespace our root `up`/`down`
# use. Upstream's default is `centaur`; we deploy into `centaur-system`.
export CENTAUR_NAMESPACE=centaur-system
