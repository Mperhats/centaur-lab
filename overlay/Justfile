set dotenv-load := true

# centaur-lab overlay — build, lint, and CLI-smoke recipes for the
# org-specific tools/skills shipped from this directory.
#
# Imported from the root Justfile via `mod overlay 'overlay/Justfile'` so
# every recipe is reachable as `just overlay::<recipe>`.

# Just module variables don't inherit `export`ed values from the parent
# Justfile, so re-resolve namespace/release from the same env vars the
# root Justfile uses. Keeps cluster recipes correct when the chart is
# installed into a non-default namespace or release name.
namespace := env_var_or_default("CENTAUR_NAMESPACE", "centaur-system")
release := env_var_or_default("CENTAUR_RELEASE", "centaur")

default:
    just --list

# Print the overlay image tag: overlay/.tag if present, else sha-<short HEAD>
# from the centaur-lab repo root (overlay/ is a subdirectory).
[group('image')]
overlay-tag:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ -f .tag ]]; then
      cat .tag
    else
      echo "sha-$(git -C .. rev-parse --short HEAD)"
    fi

# Build the overlay image with a sha-tagged local name. Docker Desktop's
# Kubernetes shares the host image cache, so a freshly-built local image is
# immediately visible to the API initContainer (with `pullPolicy: IfNotPresent`).
# Writes the tag to overlay/.tag (gitignored) for `just deploy`.
[group('image')]
build:
    #!/usr/bin/env bash
    set -euo pipefail
    tag="sha-$(git -C .. rev-parse --short HEAD)"
    docker build -t "centaur-overlay:${tag}" .
    printf '%s\n' "$tag" > .tag
    echo "Built centaur-overlay:${tag} (tag written to overlay/.tag)"

# Delete agent Sandbox CRDs (and orphaned per-sandbox iron-proxy pods) in the
# cluster namespace. Pod-only deletes respawn immediately because the Agent
# Sandbox controller keeps spec.replicas=1 on the CRD.
#
# filter:
#   all   — every {{release}}-centaur-sandbox-* CRD (default positional arg)
#   slack — only CRDs whose name contains sandbox-slack
#
# Examples:
#   just overlay::clean-sandboxes
#   just overlay::clean-sandboxes slack
[group('lifecycle')]
clean-sandboxes filter="all":
    #!/usr/bin/env bash
    set -euo pipefail
    ns="{{namespace}}"
    release="{{release}}"
    filter="{{filter}}"
    sandbox_prefix="${release}-centaur-sandbox-"
    proxy_grep='centaur-centaur-proxy-'"${sandbox_prefix}"
    deleted_crds=0

    if ! kubectl get sandboxes -n "$ns" >/dev/null 2>&1; then
      echo "No sandboxes API in namespace ${ns} — nothing to clean."
      exit 0
    fi

    echo "Deleting agent Sandbox CRDs in ${ns} (filter=${filter}) …"
    while IFS= read -r name; do
      [[ -n "$name" ]] || continue
      [[ "$name" == "${sandbox_prefix}"* ]] || continue
      if [[ "$filter" == "slack" && "$name" != *sandbox-slack* ]]; then
        continue
      fi
      kubectl delete sandbox -n "$ns" "$name" --wait=false
      deleted_crds=$((deleted_crds + 1))
      echo "  deleted sandbox/${name}"
    done < <(kubectl get sandboxes -n "$ns" -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null || true)

    if [[ "$deleted_crds" -eq 0 ]]; then
      echo "No matching Sandbox CRDs found."
    else
      echo "Deleted ${deleted_crds} Sandbox CRD(s). Pods will not respawn until the next @centaur turn."
    fi

    # CRD-only delete does not run the API's stop_by_id proxy/PVC teardown.
    deleted_proxies=0
    while IFS= read -r resource; do
      [[ -n "$resource" ]] || continue
      kubectl delete -n "$ns" "$resource" --wait=false
      deleted_proxies=$((deleted_proxies + 1))
    done < <(
      kubectl get pods,svc,configmap,networkpolicy -n "$ns" -o name 2>/dev/null \
        | grep "$proxy_grep" || true
    )
    if [[ "$deleted_proxies" -gt 0 ]]; then
      echo "Deleted ${deleted_proxies} orphaned per-sandbox iron-proxy resource(s)."
    fi

    deleted_pvcs=0
    while IFS= read -r resource; do
      [[ -n "$resource" ]] || continue
      kubectl delete -n "$ns" "$resource" --wait=false
      deleted_pvcs=$((deleted_pvcs + 1))
    done < <(
      kubectl get pvc -n "$ns" -o name 2>/dev/null \
        | grep "persistentvolumeclaim/state-${sandbox_prefix}" || true
    )
    if [[ "$deleted_pvcs" -gt 0 ]]; then
      echo "Deleted ${deleted_pvcs} orphaned sandbox state PVC(s)."
    fi

# Rebuild the overlay image and roll every runtime that copies it.
#
# Upstream Centaur has no equivalent Just recipe. Production overlay repos
# (see centaur-acme-infra) publish a sha-tagged image and let Argo CD roll
# pods when overlay.image.tag changes. Local dev mirrors that: build writes
# sha-<short> to overlay/.tag, deploy passes --set overlay.image.tag, and
# the chart checksum/overlay restarts the API. Skills still require fresh
# sandboxes — this recipe deletes Slack Sandbox CRDs after the API roll.
#
# This recipe is the local-dev loop after editing overlay/tools,
# overlay/workflows, overlay/.agents/skills, or overlay/centaur_lab:
#   1. rebuild centaur-overlay:sha-<short> and write overlay/.tag
#   2. helm deploy with overlay.image.tag (rolls API when tag changes)
#   3. rollout restart API (same-commit rebuilds reuse sha tag; Helm may not roll)
#   4. delete agent Sandbox CRDs (Slack sandboxes only)
#      spawns fresh pods with the new overlay
#
# Does NOT rebuild centaur-api / centaur-agent — use `just up` for that.
# Does NOT replace POST /admin/reload-tools, which only re-imports modules
# already on disk inside a running pod; it cannot pull in a rebuilt image.
[group('lifecycle')]
reload: build
    #!/usr/bin/env bash
    set -euo pipefail
    cd .. && just deploy
    deploy="{{release}}-centaur-api"
    echo "Restarting API deployment/${deploy} (same sha tag may skip Helm roll) …"
    kubectl rollout restart "deployment/${deploy}" -n {{namespace}}
    kubectl rollout status "deployment/${deploy}" -n {{namespace}} --timeout=120s
    just clean-sandboxes slack
    deploy="{{release}}-centaur-api"
    echo ""
    echo "Verify from the API pod:"
    echo "  kubectl exec -n {{namespace}} deploy/${deploy} -- sh -c 'ls /app/overlay/org/tools; head -n 3 /app/overlay/org/.agents/skills/academic-research/SKILL.md'"
    echo "  kubectl logs -n {{namespace}} deploy/${deploy} -c api --tail=50 | grep semantic_scholar"
    echo ""
    echo "Next Slack turn cold-spawns a sandbox with the rebuilt overlay."
    echo "To drop demo/smoke sandboxes too: just overlay::clean-sandboxes"

# Lint every tool and workflow against the same ruff contract upstream uses.
[group('dev')]
lint:
    cd tools && uvx ruff check .
    cd workflows && uvx ruff check .

# Run the workflow handler test suite locally. Workflows aren't packaged —
# uv resolves dev deps via overlay/workflows/pyproject.toml's [dependency-groups]
# without polluting the tool packages.
[group('dev')]
test-workflows:
    cd workflows && uv sync --group dev --python 3.11 && uv run --python 3.11 pytest tests/ --ignore=tests/integration -v

# Run a single org tool's test suite locally. Dev deps come from that
# tool's pyproject.toml [dependency-groups]; pytest pythonpath in the
# same file makes centaur_sdk, centaur_lab, and tools.<name>.*
# importable without conftest sys.path bootstrap.
#
# Default is semantic_scholar (the original tool with the largest suite).
# Pass any tool dirname to target a sibling: `just overlay::test-tools pdf`.
# The recipe is a no-op (and prints a friendly note) when the tool has no
# tests/ dir yet — useful for newly scaffolded tools.
[group('dev')]
test-tools tool="semantic_scholar":
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ ! -d "tools/{{tool}}/tests" ]]; then
      echo "tools/{{tool}}/tests does not exist — nothing to run."
      exit 0
    fi
    cd tools/{{tool}} && uv sync --group dev --python 3.11 && uv run --python 3.11 pytest tests/ --ignore=tests/integration -v

# Run integration tests for the save_papers workflow against a real
# Postgres. Requires CENTAUR_TEST_DATABASE_URL to point at a centaur DB
# with migrations applied (see db/README.md for the canonical port-forward
# + secret-fetch recipe). When the env var is unset every test skips with
# a clear reason rather than failing. The research_brief integration
# contract now lives with its tool method — see `test-tools-integration`.
[group('dev')]
test-workflows-integration:
    cd workflows && uv sync --group dev --python 3.11 && uv run --python 3.11 pytest tests/integration/ -v

# Run integration tests for the semantic_scholar tool methods (currently
# `research_brief`) against a real Postgres. Same gate and skip semantics
# as `test-workflows-integration` — set CENTAUR_TEST_DATABASE_URL to enable.
[group('dev')]
test-tools-integration:
    cd tools/semantic_scholar && uv sync --group dev --python 3.11 && uv run --python 3.11 pytest tests/integration/ -v

# Smoke-test the CLI without spinning up a sandbox. Honors $SEMANTIC_SCHOLAR_API_KEY
# from the root `.env` (auto-loaded above) but works without it (anonymous,
# heavily rate-limited).
[group('dev')]
smoke-semantic-scholar query="diffusion models protein design" limit="5":
    cd tools/semantic_scholar && uv run python cli.py search {{ quote(query) }} --limit {{ limit }}

# Smoke-test the research_brief tool method via the CLI subcommand.
# Goes through SemanticScholarClient.research_brief, which searches S2,
# renders the markdown lit review, and persists the brief + each citing
# paper to company_context_documents. Useful for end-to-end verification
# of the persistence path against a port-forwarded centaur_test DB. Set
# DATABASE_URL (the constructor's env / secret fallback chain picks it up)
# to your port-forwarded DSN. Defaults to --pretty so the rendered
# markdown is the only thing on stdout — pipe to `glow` for nicer
# in-terminal rendering.
[group('dev')]
smoke-research-brief query="active inference world models" limit="5":
    cd tools/semantic_scholar && uv run python cli.py research-brief {{ quote(query) }} --limit {{ limit }} --pretty

# Smoke-test the pdf tool's fetch-and-parse pipeline against any
# public PDF URL. Useful before paper_archive starts depending on
# tools/pdf to verify the fallback chain (pymupdf4llm → pymupdf → pypdf)
# resolves cleanly on the dev machine. Default URL is the Attention
# is All You Need arxiv PDF — small (~1.5 MB), parses cleanly with
# pymupdf4llm.
[group('dev')]
smoke-pdf url="https://arxiv.org/pdf/1706.03762.pdf":
    cd tools/pdf && uv run python cli.py fetch-and-parse {{ quote(url) }} --json

# Smoke-test the deployed save_papers workflow. Posts a single paper ID to
# /workflows/runs from inside the API pod so we can reuse $SLACKBOT_API_KEY
# (the chart injects it; its `agent` scope grants `agent:execute`, which the
# workflows router accepts). Default paper is the active-inference robot
# paper used in earlier semantic-scholar smokes.
[group('cluster')]
smoke-save-papers paper_id="173ba8ae4582b6f9f6919aa3f813579a5349f1f9":
    kubectl exec -n {{namespace}} deploy/{{release}}-centaur-api -- sh -c \
      'curl -sS -X POST http://localhost:8000/workflows/runs \
        -H "X-Api-Key: $SLACKBOT_API_KEY" \
        -H "Content-Type: application/json" \
        -d "{\"workflow_name\":\"save_papers\",\"input\":{\"paper_ids\":[\"{{ paper_id }}\"]}}"' \
      | jq .

# Smoke-test the DEPLOYED research_brief workflow via the API pod. Same
# auth pattern as smoke-save-papers — exec into the pod to reuse
# $SLACKBOT_API_KEY. The local CLI smoke lives at `smoke-research-brief`
# in the `dev` group; this recipe specifically exercises the workflow
# router + sandbox harness in-cluster (renamed to break the name clash
# when the CLI subcommand landed).
[group('cluster')]
smoke-research-brief-deployed query="active inference world models" limit="3":
    kubectl exec -n {{namespace}} deploy/{{release}}-centaur-api -- sh -c \
      'curl -sS -X POST http://localhost:8000/workflows/runs \
        -H "X-Api-Key: $SLACKBOT_API_KEY" \
        -H "Content-Type: application/json" \
        -d "{\"workflow_name\":\"research_brief\",\"input\":{\"query\":\"{{ query }}\",\"limit\":{{ limit }}}}"' \
      | jq .
