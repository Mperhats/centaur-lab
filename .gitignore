# Local secrets — NEVER commit
.env
.env.local
.env.*.local
!.env.example

# Python detritus (in case anything escapes the .centaur/ submodule)
__pycache__/
*.py[cod]
.venv/
venv/

# Per-tool uv lockfiles regenerated by `uv run`. The CLI is for local
# smoke-testing only; the API pod resolves tool deps from each pyproject.toml.
overlay/tools/*/uv.lock
overlay/workflows/uv.lock
# Defensive: there is no overlay/pyproject.toml, so any overlay/uv.lock
# is an orphan from `uv run` walking up the tree looking for a workspace.
overlay/uv.lock

# Node detritus
node_modules/

# Cloudflare Tunnel credentials — defensive; real ones live in ~/.cloudflared/
cloudflared/*.json
cloudflared/cert.pem

# Git worktrees (subagent-driven-development isolation)
.worktrees/

# Local overlay tag written by `just overlay::build` (Phase 2 deploy input)
overlay/.tag

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
