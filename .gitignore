# Local secrets — NEVER commit
.env
.env.local
.env.*.local
!.env.example

# Local Helm values — per centaur-acme guidance, the overlay repo
# carries no Helm values. Local laptop overrides live in a gitignored
# values*.yaml (see README's local-deploy section). Helm values for
# any cluster live in the sibling centaur-scientist-infra repo
# instead.
values*.yaml

# Python detritus (in case anything escapes the .centaur/ submodule)
__pycache__/
*.py[cod]
.venv/
venv/

# Per-tool / per-workflow uv lockfiles. The root uv.lock IS tracked
# (single-source-of-truth for the dev/test .venv). Per-tool uv.lock
# files would only appear if someone ran `uv` inside a tool directory,
# which is no longer part of the dev flow — keep these rules defensive.
tools/*/uv.lock
workflows/uv.lock

# Node detritus
node_modules/

# Git worktrees (subagent-driven-development isolation)
.worktrees/

# Local scratch directory. Never ships in the overlay image — also
# excluded by .dockerignore. Pattern (unanchored) so nested ``tmp/``
# (e.g. ``tools/<name>/tmp/``) is also ignored.
tmp/

# Ruff + pytest caches
.ruff_cache/
.pytest_cache/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
