set dotenv-load := true

here := source_directory()
config := here / "config.yml"
template := here / "com.local-labs.centaur-tunnel.plist"
label := "com.local-labs.centaur-tunnel"

# Install the Cloudflare Tunnel as a launchd user agent that auto-starts on login.
[macos]
[group('service')]
install-service:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! command -v cloudflared >/dev/null 2>&1; then
      echo "cloudflared not on PATH; run 'brew install cloudflared' first." >&2
      exit 1
    fi
    if [ ! -f "{{config}}" ]; then
      echo "missing {{config}}; see cloudflared/README.md for one-time setup." >&2
      exit 1
    fi
    mkdir -p ~/Library/LaunchAgents ~/Library/Logs
    plist=~/Library/LaunchAgents/{{label}}.plist
    log=$HOME/Library/Logs/centaur-tunnel.log
    sed \
      -e "s|__TUNNEL_BIN__|$(command -v cloudflared)|g" \
      -e "s|__CONFIG_PATH__|{{config}}|g" \
      -e "s|__LOG_PATH__|$log|g" \
      "{{template}}" > "$plist"
    launchctl bootout "gui/$(id -u)/{{label}}" 2>/dev/null || true
    launchctl bootstrap "gui/$(id -u)" "$plist"
    echo "installed {{label}}; logs at $log"

# Boot out the launch agent and remove its plist.
[macos]
[group('service')]
[confirm("Uninstall the centaur-tunnel launch agent? Pass --yes to skip this prompt. ")]
uninstall-service:
    #!/usr/bin/env bash
    set -euo pipefail
    plist=~/Library/LaunchAgents/{{label}}.plist
    launchctl bootout "gui/$(id -u)/{{label}}" 2>/dev/null || true
    rm -f "$plist"
    echo "uninstalled {{label}}"

# Show whether the launch agent is loaded and running.
[macos]
[group('service')]
status:
    launchctl print "gui/$(id -u)/{{label}}" 2>&1 | grep -E "^\s*(state|pid|path|program) " || echo "not loaded"

# Tail the launch agent's combined stdout/stderr log.
[macos]
[group('service')]
logs:
    tail -f ~/Library/Logs/centaur-tunnel.log

# Foreground run for debugging — uninstall the service first to avoid a connector race.
[group('debug')]
run:
    cloudflared tunnel --config "{{config}}" run centaur-dev
